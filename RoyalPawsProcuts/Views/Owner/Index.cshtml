@model IEnumerable<RoyalPawsProcuts.Models.Owner>

@{
    ViewData["Title"] = "Owners";
}

<h1>Owners</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FullName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PhoneNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            @* <th>
                @Html.DisplayNameFor(model => model.Pet)
            </th> *@
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.FullName)
            </td>
            <td>
                @Html.DisplayFor(model => item.PhoneNumber)
            </td>
            <td>
                @Html.DisplayFor(model => item.Email)
            </td>
            @* <td>
                @Html.DisplayFor(model => item.Pet)
            </td> *@
            <td>
                <a asp-action="Edit" asp-route-id="@item.OwnerId">Edit</a> |
                @* <a asp-action="Details" asp-route-id="@item.OwnerId">Details</a> | *@
                <a asp-action="Delete" asp-route-id="@item.OwnerId" onclick="return confirmDelete()">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
