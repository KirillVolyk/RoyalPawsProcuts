@model IEnumerable<RoyalPawsProcuts.Models.Pet>

@{
    ViewData["Title"] = "Pets";
}

<h1>Pets</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PetName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Species)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Breed)
            </th>
            <th>
                Owner
            </th>
            @* <th>
                @Html.DisplayNameFor(model => model.Owner)
            </th> *@
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.PetName</td>
                <td>@item.Species</td>
                <td>@item.Breed</td>

                @* show ownesr name *@
                <td>@item.Owner.FullName</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.PetId">Edit</a> |
                    @* <a asp-action="Details" asp-route-id="@item.PetId">Details</a> | *@
                    <a asp-action="Delete" asp-route-id="@item.PetId">Delete</a>
                </td>
            </tr>
}
    </tbody>
</table>
